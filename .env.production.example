# ═══════════════════════════════════════════════════════════════════
#  ECCELLERE — PRODUCTION ENVIRONMENT TEMPLATE
#  Copy this file to .env and fill in all values before deploying.
#  NEVER commit the actual .env file to git.
# ═══════════════════════════════════════════════════════════════════

# ── Database (PostgreSQL) ──────────────────────────────────────────
# Hostinger: Create a PostgreSQL database in hPanel → Databases
# Connection string format:
#   postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
DATABASE_URL="postgresql://eccellere_user:STRONG_PASSWORD@localhost:5432/eccellere?schema=public"

# ── NextAuth ───────────────────────────────────────────────────────
# NEXTAUTH_URL must be your live domain (with https://)
NEXTAUTH_URL="https://eccellere.in"
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_64_CHAR_RANDOM_SECRET"

# ── Razorpay (Payment Gateway) ─────────────────────────────────────
# Get from https://dashboard.razorpay.com → Settings → API Keys
# Use TEST keys for staging, LIVE keys for production
RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
RAZORPAY_WEBHOOK_SECRET="REPLACE_WITH_RAZORPAY_WEBHOOK_SECRET"
# Also add public key for frontend checkout
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXXXXXXXX"

# ── Email (SMTP) ───────────────────────────────────────────────────
# Hostinger business email via hPanel → Email Accounts
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="contact@eccellere.in"
SMTP_PASS="YOUR_EMAIL_PASSWORD"
EMAIL_FROM="contact@eccellere.in"

# ── Google OAuth (optional) ────────────────────────────────────────
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Storage ────────────────────────────────────────────────────────
# "local" = store uploads on disk (default, works on Hostinger VPS)
# "s3"    = store on AWS S3 (requires AWS keys below)
STORAGE_PROVIDER="local"

# Required only if STORAGE_PROVIDER="s3":
# AWS_S3_BUCKET="eccellere-assets"
# AWS_REGION="ap-south-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# CDN_DOMAIN=""

# ── Application ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://eccellere.in"
NODE_ENV="production"
