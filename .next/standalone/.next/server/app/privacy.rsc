17:["$","div",null,{"children":[["$","h2",null,{"className":"text-xl font-semibold text-gray-900 mb-3","children":"6. Data Sharing"}],["$","p",null,{"children":"We do not sell your personal data. We may share your data with trusted third parties only when necessary:"}],["$","ul",null,{"className":"list-disc ml-6 mt-3 space-y-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Payment processors"}]," (Razorpay) — to process payments securely. They are PCI-DSS compliant and governed by their own privacy policies."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cloud infrastructure providers"}]," (Vercel, AWS) — for hosting and storage."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Analytics providers"}]," (Google Analytics, PostHog) — for usage insights, subject to your consent and our cookie settings."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Error monitoring"}]," (Sentry) — for application error tracking."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Email service providers"}]," — to send transactional and marketing emails."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal authorities"}]," — when required by law, court order, or to protect our rights."]}]]}],["$","p",null,{"className":"mt-3","children":"All third-party service providers are contractually bound to handle your data securely and only for the purposes we specify."}]]}]
18:["$","div",null,{"children":[["$","h2",null,{"className":"text-xl font-semibold text-gray-900 mb-3","children":"7. Data Retention"}],["$","p",null,{"children":"We retain personal data only for as long as necessary for the purposes outlined in this Policy, or as required by law:"}],["$","ul",null,{"className":"list-disc ml-6 mt-3 space-y-2","children":[["$","li",null,{"children":"Account data: for the duration of your account plus 3 years after closure."}],["$","li",null,{"children":"Transaction data: 7 years for statutory compliance."}],["$","li",null,{"children":"Marketing data: until you withdraw consent or unsubscribe."}],["$","li",null,{"children":"Usage analytics: aggregated data retained for up to 26 months."}]]}]]}]
19:["$","div",null,{"children":[["$","h2",null,{"className":"text-xl font-semibold text-gray-900 mb-3","children":"8. Your Rights"}],["$","p",null,{"children":"Under the DPDP Act, 2023, you have the following rights as a Data Principal:"}],["$","ul",null,{"className":"list-disc ml-6 mt-3 space-y-2","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Right to access:"}]," Request a summary of personal data we hold about you."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to correction:"}]," Request correction of inaccurate or incomplete data."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to erasure:"}]," Request deletion of your personal data, subject to legal retention obligations."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to grievance redressal:"}]," Raise a grievance with our Data Protection Officer; we will respond within 30 days."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to nominate:"}]," Nominate another individual to exercise rights on your behalf in case of death or incapacity."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to withdraw consent:"}]," Withdraw consent for marketing or analytics processing at any time."]}]]}],["$","p",null,{"className":"mt-3","children":["To exercise any of these rights, email"," ",["$","a",null,{"href":"mailto:privacy@eccellere.in","className":"text-amber-700 underline underline-offset-2 hover:text-amber-900","children":"privacy@eccellere.in"}],". We may ask you to verify your identity before processing the request."]}]]}]
